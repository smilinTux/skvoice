[Service]
Type=simple
WorkingDirectory=/home/cbrd21/clawd/skcapstone-repos/skvoice
ExecStart=/home/cbrd21/chatterbox-env/bin/python -m skvoice
Environment="SKVOICE_PORT=18800"
Environment="SKVOICE_AGENT=lumina"
