# SKVoice — example environment configuration.
# Copy to ~/.config/skvoice/skvoice.env (or anywhere systemd EnvironmentFile= points)
# and edit. All variables are optional — defaults assume STT/TTS run on
# localhost.

# --- Service ----------------------------------------------------------------
SKVOICE_PORT=18800
SKVOICE_AGENT=lumina

# --- LLM --------------------------------------------------------------------
SKVOICE_MODEL=claude-sonnet-4-6
SKVOICE_MAX_TOKENS=200

# --- STT / TTS endpoints (distributed deployment) ---------------------------
# In a distributed deployment the orchestrator (this service) runs on one
# host and the GPU services run on another. Point at the GPU host using
# either its tailnet name (preferred — survives LAN changes) or LAN IP.
#
# Easiest: set the BASE URL and let SKVoice append the standard paths.
#SKVOICE_TTS_BASE=http://skworld-100:18793
#SKVOICE_STT_BASE=http://skworld-100:18794
#
# Or: set the full URL if you have a non-standard path.
#SKVOICE_TTS_URL=http://skworld-100:18793/audio/speech
#SKVOICE_STT_URL=http://skworld-100:18794/v1/audio/transcriptions
#
# Legacy alias (matches the v0.1.0 README) — still accepted:
#SKVOICE_WHISPER_URL=http://skworld-100:18794

# --- Paths ------------------------------------------------------------------
#SKVOICE_CREDENTIALS_PATH=~/.claude/.credentials.json
#SKVOICE_AGENT_HOME=~/.skcapstone/agents

# --- Ollama fallback (used if Anthropic credentials missing) ----------------
#SKVOICE_OLLAMA_URL=http://localhost:11434/api/chat
#SKVOICE_OLLAMA_MODEL=qwen3.5:9b
